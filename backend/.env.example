# Copy this file to .env and fill in your real values
# NEVER put real credentials in this file

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# NOTE: Etsy API access was rejected for individual developers (May 2026)
# We use Gmail API to parse Etsy notification emails instead
# Keeping these fields in case Etsy opens API access in future
ETSY_API_KEY=your_etsy_api_key
ETSY_SHOP_ID=your_etsy_shop_id
ETSY_SHARED_SECRET=

# Developer account registered May 2026 - pending approval (1 business day)
# Orders + messages covered via Gmail OAuth in the meantime
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_AUTH_TOKEN=your_ebay_auth_token

STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

ANTHROPIC_API_KEY=your_anthropic_key_here

POLL_INTERVAL_MINUTES=5
ENVIRONMENT=development